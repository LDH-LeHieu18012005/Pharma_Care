<div class="d-flex justify-content-between mb-3"><h5>Khách hàng</h5><a href="/admin/customer/create" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Thêm</a></div>
<div class="card"><div class="card-body p-0"><table class="table table-hover mb-0"><thead><tr><th>#</th><th>Tên KH</th><th>Tuổi</th><th>Giới tính</th><th>SĐT</th><th>Địa chỉ</th><th>Thao tác</th></tr></thead>
<tbody><% (items||[]).forEach((c,i) => { %><tr><td><%= i+1 %></td><td><%= c.name_customer %></td><td><%= c.age_customer||'' %></td><td><%= c.gender_customer||'' %></td><td><%= c.phone_customer||'' %></td><td><%= c.address_customer||'' %></td>
<td><a href="/admin/customer/edit/<%= c.id_customer %>" class="btn btn-warning btn-sm"><i class="bi bi-pencil"></i></a> <form method="POST" action="/admin/customer/delete/<%= c.id_customer %>" class="d-inline" onsubmit="return confirm('Xóa?')"><button class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button></form></td></tr><% }) %></tbody></table></div></div>

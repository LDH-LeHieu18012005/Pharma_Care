<%- /* Customer List - Search + Pagination */ %>
<div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-2">
  <h5 class="mb-0">Khách hàng <span class="badge bg-primary fs-6"><%= pagination.total %></span></h5>
  <div class="d-flex gap-2">
    <a href="/admin/export/customer/excel" class="btn btn-success btn-sm"><i class="bi bi-file-earmark-excel"></i> Xuất Excel</a>
    <a href="/admin/customer/create" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Thêm</a>
  </div>
</div>

<div class="card mb-3">
  <div class="card-body py-2">
    <form method="GET" action="/admin/customer" class="row g-2 align-items-end">
      <div class="col-md-5">
        <label class="form-label small mb-1">Tìm theo tên hoặc SĐT</label>
        <div class="input-group input-group-sm">
          <span class="input-group-text"><i class="bi bi-search"></i></span>
          <input type="text" name="keyword" class="form-control" placeholder="Tên khách / Số điện thoại..." value="<%= filters.keyword %>">
        </div>
      </div>
      <div class="col-md-3 d-flex gap-2">
        <button type="submit" class="btn btn-primary btn-sm flex-grow-1"><i class="bi bi-funnel"></i> Tìm kiếm</button>
        <a href="/admin/customer" class="btn btn-outline-secondary btn-sm"><i class="bi bi-x"></i> Xóa</a>
      </div>
    </form>
  </div>
</div>

<div class="card">
  <div class="card-body p-0">
    <table class="table table-hover mb-0">
      <thead>
        <tr><th>#</th><th>Tên KH</th><th>Tuổi</th><th>Giới tính</th><th>SĐT</th><th>Địa chỉ</th><th>Thao tác</th></tr>
      </thead>
      <tbody>
      <% if ((items||[]).length === 0) { %>
        <tr><td colspan="7" class="text-center text-muted py-4"><i class="bi bi-inbox fs-4 d-block mb-2"></i>Không có khách hàng nào</td></tr>
      <% } %>
      <% (items||[]).forEach((c, i) => { %>
        <tr>
          <td><%= (pagination.currentPage - 1) * pagination.limit + i + 1 %></td>
          <td><strong><%= c.name_customer %></strong></td>
          <td><%= c.age_customer || '' %></td>
          <td><%= c.gender_customer || '' %></td>
          <td><%= c.phone_customer || '' %></td>
          <td><%= c.address_customer || '' %></td>
          <td>
            <a href="/admin/customer/edit/<%= c.id_customer %>" class="btn btn-warning btn-sm"><i class="bi bi-pencil"></i></a>
            <form method="POST" action="/admin/customer/delete/<%= c.id_customer %>" class="d-inline" onsubmit="return confirm('Xóa khách hàng này?')">
              <button class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button>
            </form>
          </td>
        </tr>
      <% }) %>
      </tbody>
    </table>
  </div>
</div>
<%- include('../_pagination', { currentPage: pagination.currentPage, totalPages: pagination.totalPages, total: pagination.total, query: query, baseUrl: '/admin/customer' }) %>

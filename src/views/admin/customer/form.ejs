<div class="card"><div class="card-body"><form method="POST" action="/admin/customer/<%= item ? 'edit/'+item.id_customer : 'create' %>">
  <div class="row g-3">
    <div class="col-md-6"><label class="form-label">Tên KH *</label><input type="text" name="name_customer" class="form-control" value="<%= item ? item.name_customer : '' %>" required></div>
    <div class="col-md-3"><label class="form-label">Tuổi</label><input type="number" name="age_customer" class="form-control" value="<%= item ? item.age_customer || '' : '' %>"></div>
    <div class="col-md-3"><label class="form-label">Giới tính</label><select name="gender_customer" class="form-select"><option value="Nam" <%= item && item.gender_customer=='Nam'?'selected':'' %>>Nam</option><option value="Nu" <%= item && item.gender_customer=='Nu'?'selected':'' %>>Nữ</option><option value="Khac" <%= item && item.gender_customer=='Khac'?'selected':'' %>>Khác</option></select></div>
    <div class="col-md-6"><label class="form-label">SĐT</label><input type="text" name="phone_customer" class="form-control" value="<%= item ? item.phone_customer || '' : '' %>"></div>
    <div class="col-md-6"><label class="form-label">Địa chỉ</label><input type="text" name="address_customer" class="form-control" value="<%= item ? item.address_customer || '' : '' %>"></div>
  </div>
  <div class="mt-3"><button class="btn btn-primary"><%= item ? 'Cập nhật' : 'Thêm mới' %></button> <a href="/admin/customer" class="btn btn-secondary">Hủy</a></div>
</form></div></div>

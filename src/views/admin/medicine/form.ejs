<div class="card"><div class="card-body">
<form method="POST" action="/admin/medicine/<%= item ? 'edit/'+item.id_medicine : 'create' %>" enctype="multipart/form-data">
  <div class="row g-3">
    <div class="col-md-6"><label class="form-label">Tên thuốc *</label><input type="text" name="name_medicine" class="form-control" value="<%= item ? item.name_medicine : '' %>" required></div>
    <div class="col-md-3"><label class="form-label">Giá *</label><input type="number" name="price" class="form-control" value="<%= item ? item.price : '' %>" required></div>
    <div class="col-md-3"><label class="form-label">Số lượng</label><input type="number" name="quantity_total" class="form-control" value="<%= item ? item.quantity_total : 0 %>"></div>
    <div class="col-md-4"><label class="form-label">Loại thuốc</label><select name="id_type" class="form-select"><% (types||[]).forEach(t => { %><option value="<%= t.id_type %>" <%= item && item.id_type==t.id_type?'selected':'' %>><%= t.name_type %></option><% }) %></select></div>
    <div class="col-md-4"><label class="form-label">Kệ thuốc</label><select name="id_rack" class="form-select"><option value="">-- Chọn --</option><% (racks||[]).forEach(r => { %><option value="<%= r.id_rack %>" <%= item && item.id_rack==r.id_rack?'selected':'' %>><%= r.name_rack %></option><% }) %></select></div>
    <div class="col-md-4"><label class="form-label">Trạng thái</label><select name="medicine_status" class="form-select"><option value="con_hang" <%= item && item.medicine_status=='con_hang'?'selected':'' %>>Còn hàng</option><option value="het_hang" <%= item && item.medicine_status=='het_hang'?'selected':'' %>>Hết hàng</option><option value="ngung_kinh_doanh" <%= item && item.medicine_status=='ngung_kinh_doanh'?'selected':'' %>>Ngừng KD</option></select></div>
    <div class="col-md-4"><label class="form-label">Ngày sản xuất</label><input type="date" name="manufacturing_date" class="form-control" value="<%= item && item.manufacturing_date ? new Date(item.manufacturing_date).toISOString().split('T')[0] : '' %>"></div>
    <div class="col-md-4"><label class="form-label">Hạn dùng</label><input type="date" name="expiry_date" class="form-control" value="<%= item && item.expiry_date ? new Date(item.expiry_date).toISOString().split('T')[0] : '' %>"></div>
    <div class="col-md-4"><label class="form-label">Hình ảnh thuốc</label><input type="file" name="image_file" class="form-control" accept="image/*">
    <% if(item && item.images) { %><small class="text-success"><i class="bi bi-check-circle"></i> Đã có ảnh</small><% } %>
    </div>
    <div class="col-12"><label class="form-label">Mô tả</label><textarea name="descriptions" class="form-control" rows="3"><%= item ? item.descriptions || '' : '' %></textarea></div>
  </div>
  <div class="mt-3"><button class="btn btn-primary"><i class="bi bi-check-lg"></i> <%= item ? 'Cập nhật' : 'Thêm mới' %></button> <a href="/admin/medicine" class="btn btn-secondary">Hủy</a></div>
</form>
</div></div>

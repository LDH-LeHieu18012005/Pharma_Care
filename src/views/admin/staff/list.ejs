<div class="d-flex justify-content-between mb-3"><h5>Nhân viên</h5><a href="/admin/staff/create" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Thêm</a></div>
<div class="card"><div class="card-body p-0"><table class="table table-hover mb-0"><thead><tr><th>#</th><th>Tên NV</th><th>Username</th><th>SĐT</th><th>Quyền</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
<tbody><% (items||[]).forEach((s,i) => { %><tr><td><%= i+1 %></td><td><%= s.name_staff %></td><td><%= s.username %></td><td><%= s.phone_staff||'' %></td>
<td><span class="badge bg-<%= s.permission=='admin'?'danger':'primary' %>"><%= s.permission %></span></td>
<td><span class="badge bg-<%= s.status==1?'success':'secondary' %>"><%= s.status==1?'Active':'Inactive' %></span></td>
<td><a href="/admin/staff/edit/<%= s.id_staff %>" class="btn btn-warning btn-sm"><i class="bi bi-pencil"></i></a> <form method="POST" action="/admin/staff/delete/<%= s.id_staff %>" class="d-inline" onsubmit="return confirm('Xóa?')"><button class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button></form></td></tr><% }) %></tbody></table></div></div>

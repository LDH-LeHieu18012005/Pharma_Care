<div class="card"><div class="card-body"><form method="POST" action="/admin/staff/<%= item ? 'edit/'+item.id_staff : 'create' %>" enctype="multipart/form-data">
  <div class="row g-3">
    <div class="col-md-6"><label class="form-label">Họ tên *</label><input type="text" name="name_staff" class="form-control" value="<%= item ? item.name_staff : '' %>" required></div>
    <div class="col-md-3"><label class="form-label">Username *</label><input type="text" name="username" class="form-control" value="<%= item ? item.username : '' %>" required></div>
    <div class="col-md-3"><label class="form-label"><%= item ? 'Đổi mật khẩu' : 'Mật khẩu *' %></label><input type="password" name="password" class="form-control" <%= item ? '' : 'required' %>></div>
    <div class="col-md-3"><label class="form-label">Tuổi</label><input type="number" name="age_staff" class="form-control" value="<%= item ? item.age_staff || '' : '' %>"></div>
    <div class="col-md-3"><label class="form-label">Giới tính</label><select name="gender_staff" class="form-select"><option value="Nam" <%= item && item.gender_staff=='Nam'?'selected':'' %>>Nam</option><option value="Nu" <%= item && item.gender_staff=='Nu'?'selected':'' %>>Nữ</option></select></div>
    <div class="col-md-3"><label class="form-label">SĐT</label><input type="text" name="phone_staff" class="form-control" value="<%= item ? item.phone_staff || '' : '' %>"></div>
    <div class="col-md-3"><label class="form-label">Quyền</label><select name="permission" class="form-select"><option value="staff" <%= item && item.permission=='staff'?'selected':'' %>>Nhân viên</option><option value="admin" <%= item && item.permission=='admin'?'selected':'' %>>Admin</option></select></div>
    <div class="col-md-6"><label class="form-label">Email</label><input type="email" name="gmail_staff" class="form-control" value="<%= item ? item.gmail_staff || '' : '' %>"></div>
    <div class="col-md-6"><label class="form-label">Địa chỉ</label><input type="text" name="address_staff" class="form-control" value="<%= item ? item.address_staff || '' : '' %>"></div>
    <div class="col-12">
      <label class="form-label">Ảnh đại diện</label><input type="file" name="image_file" class="form-control" accept="image/*">
      <% if(item && item.images) { %><small class="text-success"><i class="bi bi-check-circle"></i> Đã có ảnh</small><% } %>
    </div>
  </div>
  <div class="mt-3"><button class="btn btn-primary"><%= item ? 'Cập nhật' : 'Thêm mới' %></button> <a href="/admin/staff" class="btn btn-secondary">Hủy</a></div>
</form></div></div>

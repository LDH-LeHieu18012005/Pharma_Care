<div class='container'>
  <h1>Quản lý Loại thuốc</h1>
  <a href='/admin/categories/create'>+ Thêm loại thuốc</a>
  <% const rows = Array.isArray(items) ? items : []; %>
  <% if (!rows.length) { %>
    <p>Chưa có dữ liệu.</p>
  <% } else { %>
    <table border='1' cellpadding='8' cellspacing='0'>
      <thead>
        <tr>
          <% Object.keys(rows[0]).forEach(function(key) { %>
            <th><%= key %></th>
          <% }) %>
          <th>Hành động</th>
        </tr>
      </thead>
      <tbody>
        <% rows.forEach(function(row) { %>
          <tr>
            <% Object.keys(rows[0]).forEach(function(key) { %>
              <td><%= row[key] %></td>
            <% }) %>
            <td><a href='/admin/categories/edit/<%= row.id %>'>Sửa</a></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>

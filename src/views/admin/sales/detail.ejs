<div class="d-flex justify-content-between mb-3">
  <a href="/admin/sales" class="btn btn-secondary btn-sm"><i class="bi bi-arrow-left"></i> Quay lại</a>
  <a href="/admin/sales/print/<%= item.id_sales %>" target="_blank" class="btn btn-dark btn-sm"><i class="bi bi-printer"></i> In Hóa Đơn</a>
</div>
<div class="card mb-4"><div class="card-body">
  <div class="row">
    <div class="col-md-6">
      <h6>Thông tin hóa đơn #HD-<%= item.id_sales %></h6>
      <p class="mb-1">Khách hàng: <strong><%= item.name_customer || 'Khách lẻ' %></strong></p>
      <p class="mb-1">Nhân viên: <strong><%= item.name_staff %></strong></p>
    </div>
    <div class="col-md-6 text-end">
      <p class="mb-1">Ngày: <%= new Date(item.date_create).toLocaleString('vi-VN') %></p>
      <div class="d-flex justify-content-end align-items-center gap-2 mt-2">
        <span>Trạng thái: </span>
        <form action="/admin/sales/status/<%= item.id_sales %>" method="POST" class="d-inline-flex gap-2">
          <select name="status" class="form-select form-select-sm" style="width: auto;">
            <option value="cho_xu_ly" <%= item.status == 'cho_xu_ly' ? 'selected' : '' %>>Chờ xử lý</option>
            <option value="da_thanh_toan" <%= item.status == 'da_thanh_toan' ? 'selected' : '' %>>Đã thanh toán (Hoàn thành)</option>
            <option value="da_huy" <%= item.status == 'da_huy' ? 'selected' : '' %>>Đã hủy</option>
          </select>
          <button type="submit" class="btn btn-primary btn-sm">Cập nhật</button>
        </form>
      </div>
    </div>
  </div>
</div></div>
<% if (item.prescription_image) { %>
<div class="card mb-4"><div class="card-header fw-bold">Hình ảnh đơn thuốc</div><div class="card-body">
  <img src="<%= item.prescription_image %>" alt="Đơn thuốc" class="img-fluid rounded" style="max-height: 400px; object-fit: contain;">
</div></div>
<% } %>
<div class="card"><div class="card-header fw-bold">Chi tiết sản phẩm</div><div class="card-body p-0">
<table class="table table-hover mb-0"><thead><tr><th>Thuốc</th><th class="text-center">Số lượng</th><th class="text-end">Đơn giá</th><th class="text-end">Thành tiền</th></tr></thead>
<tbody>
  <% let total = 0; (details||[]).forEach((d) => { const st = d.quantity_sales * d.price; total += st; %>
  <tr><td><%= d.name_medicine %></td><td class="text-center"><%= d.quantity_sales %></td><td class="text-end"><%= Number(d.price).toLocaleString('vi-VN') %>đ</td><td class="text-end"><%= Number(st).toLocaleString('vi-VN') %>đ</td></tr>
  <% }) %>
</tbody>
<tfoot class="table-light"><tr><th colspan="3" class="text-end">Tổng cộng:</th><th class="text-end fs-5 text-primary"><%= Number(total).toLocaleString('vi-VN') %>đ</th></tr></tfoot>
</table></div></div>

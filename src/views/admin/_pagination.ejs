<%
  // pagination partial
  // Props: currentPage, totalPages, query (req.query object), baseUrl (string)
  const maxVisible = 5;
  const half = Math.floor(maxVisible / 2);
  let startPage = Math.max(1, currentPage - half);
  let endPage = Math.min(totalPages, startPage + maxVisible - 1);
  if (endPage - startPage < maxVisible - 1) {
    startPage = Math.max(1, endPage - maxVisible + 1);
  }

  function pageUrl(p) {
    const q = Object.assign({}, query, { page: p });
    return baseUrl + '?' + Object.entries(q)
      .filter(([, v]) => v !== '' && v !== undefined && v !== null)
      .map(([k, v]) => encodeURIComponent(k) + '=' + encodeURIComponent(v))
      .join('&');
  }
%>
<% if (totalPages > 1) { %>
<nav aria-label="Phân trang" class="mt-3">
  <div class="d-flex align-items-center justify-content-between flex-wrap gap-2">
    <div class="text-muted small">
      Trang <strong><%= currentPage %></strong> / <strong><%= totalPages %></strong>
      &nbsp;·&nbsp; Tổng <strong><%= total %></strong> bản ghi
    </div>
    <ul class="pagination pagination-sm mb-0">
      <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
        <a class="page-link" href="<%= pageUrl(1) %>" title="Trang đầu"><i class="bi bi-chevron-double-left"></i></a>
      </li>
      <li class="page-item <%= currentPage === 1 ? 'disabled' : '' %>">
        <a class="page-link" href="<%= pageUrl(currentPage - 1) %>"><i class="bi bi-chevron-left"></i></a>
      </li>
      <% for (let p = startPage; p <= endPage; p++) { %>
      <li class="page-item <%= p === currentPage ? 'active' : '' %>">
        <a class="page-link" href="<%= pageUrl(p) %>"><%= p %></a>
      </li>
      <% } %>
      <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="<%= pageUrl(currentPage + 1) %>"><i class="bi bi-chevron-right"></i></a>
      </li>
      <li class="page-item <%= currentPage === totalPages ? 'disabled' : '' %>">
        <a class="page-link" href="<%= pageUrl(totalPages) %>" title="Trang cuối"><i class="bi bi-chevron-double-right"></i></a>
      </li>
    </ul>
  </div>
</nav>
<% } %>

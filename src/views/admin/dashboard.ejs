<%# Dashboard - Stats + Charts %>

<%# Bộ lọc năm %>
<div class="d-flex justify-content-between align-items-center mb-4">
  <div></div>
  <form method="GET" action="/admin" class="d-flex align-items-center gap-2">
    <label class="text-muted small mb-0">Năm thống kê:</label>
    <select name="year" class="form-select form-select-sm" style="width:auto" onchange="this.form.submit()">
      <% years.forEach(y => { %>
        <option value="<%= y %>" <%= y === year ? 'selected' : '' %>><%= y %></option>
      <% }) %>
    </select>
    <a href="/admin/export/report/excel?year=<%= year %>" class="btn btn-success btn-sm">
      <i class="bi bi-file-earmark-excel"></i> Xuất báo cáo
    </a>
  </form>
</div>

<%# Widget tổng quan %>
<div class="row g-3 mb-4">
  <div class="col-6 col-md-3">
    <div class="card card-stat h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-primary bg-opacity-10 text-primary"><i class="bi bi-capsule"></i></div>
        <div>
          <div class="text-muted small">Tổng thuốc</div>
          <div class="fs-4 fw-bold"><%= summary.totalMedicine %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card card-stat h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-success bg-opacity-10 text-success"><i class="bi bi-people"></i></div>
        <div>
          <div class="text-muted small">Khách hàng</div>
          <div class="fs-4 fw-bold"><%= summary.totalCustomer %></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card card-stat h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-warning bg-opacity-10 text-warning"><i class="bi bi-receipt"></i></div>
        <div>
          <div class="text-muted small">Tổng đơn hàng</div>
          <div class="fs-4 fw-bold"><%= summary.totalSales %></div>
          <div class="text-muted" style="font-size:0.75rem">Hôm nay: <strong class="text-warning"><%= summary.todaySales %></strong></div>
        </div>
      </div>
    </div>
  </div>
  <div class="col-6 col-md-3">
    <div class="card card-stat h-100">
      <div class="card-body d-flex align-items-center gap-3">
        <div class="stat-icon bg-info bg-opacity-10 text-info"><i class="bi bi-currency-dollar"></i></div>
        <div>
          <div class="text-muted small">Doanh thu</div>
          <div class="fs-5 fw-bold"><%= Number(summary.totalRevenue).toLocaleString('vi-VN') %>đ</div>
          <div class="text-muted" style="font-size:0.75rem">Hôm nay: <strong class="text-info"><%= Number(summary.todayRevenue).toLocaleString('vi-VN') %>đ</strong></div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Charts row 1 - Line Chart doanh thu %>
<div class="row g-3 mb-4">
  <div class="col-lg-8">
    <div class="card h-100">
      <div class="card-header d-flex justify-content-between align-items-center">
        <span class="fw-semibold"><i class="bi bi-graph-up-arrow text-primary me-2"></i>Doanh thu theo tháng năm <%= year %></span>
      </div>
      <div class="card-body">
        <canvas id="revenueChart" style="max-height: 280px;"></canvas>
      </div>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card h-100">
      <div class="card-header fw-semibold">
        <i class="bi bi-pie-chart text-info me-2"></i>Trạng thái đơn hàng
      </div>
      <div class="card-body d-flex flex-column align-items-center justify-content-center">
        <canvas id="statusChart" style="max-height: 220px;"></canvas>
        <div class="mt-3 w-100">
          <div class="d-flex justify-content-between small"><span><span class="badge bg-warning me-1">●</span>Chờ xử lý</span><strong><%= salesByStatus.cho_xu_ly %></strong></div>
          <div class="d-flex justify-content-between small"><span><span class="badge bg-success me-1">●</span>Đã thanh toán</span><strong><%= salesByStatus.da_thanh_toan %></strong></div>
          <div class="d-flex justify-content-between small"><span><span class="badge bg-danger me-1">●</span>Đã hủy</span><strong><%= salesByStatus.da_huy %></strong></div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Charts row 2 - Bar Chart top medicines %>
<div class="row g-3 mb-4">
  <div class="col-lg-6">
    <div class="card h-100">
      <div class="card-header fw-semibold">
        <i class="bi bi-bar-chart text-success me-2"></i>Top 5 thuốc bán chạy nhất
      </div>
      <div class="card-body">
        <canvas id="topMedChart" style="max-height: 240px;"></canvas>
      </div>
    </div>
  </div>
  <div class="col-lg-6">
    <div class="row g-3 h-100">
      <div class="col-12">
        <div class="card">
          <div class="card-header fw-semibold"><i class="bi bi-exclamation-triangle text-warning"></i> Thuốc sắp hết tồn</div>
          <div class="card-body p-0">
            <table class="table table-sm mb-0">
              <thead><tr><th>Tên thuốc</th><th>Tồn kho</th></tr></thead>
              <tbody>
                <% (lowStock || []).forEach(m => { %>
                <tr>
                  <td><%= m.name_medicine %></td>
                  <td><span class="badge bg-<%= m.quantity_total <= 10 ? 'danger' : 'warning' %>"><%= m.quantity_total %></span></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
      <div class="col-12">
        <div class="card">
          <div class="card-header fw-semibold"><i class="bi bi-clock text-danger"></i> Lô hàng sắp hết hạn</div>
          <div class="card-body p-0">
            <table class="table table-sm mb-0">
              <thead><tr><th>Thuốc</th><th>Hạn dùng</th></tr></thead>
              <tbody>
                <% (expiring || []).forEach(b => { %>
                <tr>
                  <td><%= b.name_medicine %></td>
                  <td class="text-danger"><%= b.expiry_date ? new Date(b.expiry_date).toLocaleDateString('vi-VN') : '' %></td>
                </tr>
                <% }) %>
              </tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<%# Chart.js CDN + Init Scripts %>
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.3/dist/chart.umd.min.js"></script>
<script>
  const revenueData = <%- JSON.stringify(revenueByMonth) %>;
  const topMedData  = <%- JSON.stringify(topMedicines) %>;
  const statusData  = <%- JSON.stringify(salesByStatus) %>;

  // ── 1. Line Chart: Doanh thu theo tháng ──────────────────────────
  new Chart(document.getElementById('revenueChart'), {
    type: 'line',
    data: {
      labels: revenueData.map(d => 'T' + d.month),
      datasets: [{
        label: 'Doanh thu (đ)',
        data: revenueData.map(d => d.revenue),
        borderColor: '#2563eb',
        backgroundColor: 'rgba(37,99,235,0.1)',
        fill: true,
        tension: 0.4,
        pointBackgroundColor: '#2563eb',
        pointRadius: 5,
        pointHoverRadius: 7
      }, {
        label: 'Số đơn',
        data: revenueData.map(d => d.orders),
        borderColor: '#16a34a',
        backgroundColor: 'rgba(22,163,74,0.1)',
        fill: false,
        tension: 0.4,
        yAxisID: 'y2',
        pointRadius: 4,
        pointHoverRadius: 6
      }]
    },
    options: {
      responsive: true,
      interaction: { mode: 'index', intersect: false },
      plugins: {
        legend: { position: 'top' },
        tooltip: {
          callbacks: {
            label: (ctx) => {
              if (ctx.datasetIndex === 0) return ' Doanh thu: ' + Number(ctx.raw).toLocaleString('vi-VN') + 'đ';
              return ' Số đơn: ' + ctx.raw;
            }
          }
        }
      },
      scales: {
        y: { ticks: { callback: v => (v/1000000).toFixed(1) + 'M' }, title: { display: true, text: 'Doanh thu' } },
        y2: { position: 'right', grid: { drawOnChartArea: false }, title: { display: true, text: 'Số đơn' } }
      }
    }
  });

  // ── 2. Doughnut: Trạng thái đơn hàng ─────────────────────────────
  new Chart(document.getElementById('statusChart'), {
    type: 'doughnut',
    data: {
      labels: ['Chờ xử lý', 'Đã thanh toán', 'Đã hủy'],
      datasets: [{
        data: [statusData.cho_xu_ly, statusData.da_thanh_toan, statusData.da_huy],
        backgroundColor: ['#f59e0b', '#16a34a', '#dc2626'],
        borderWidth: 2,
        borderColor: '#fff'
      }]
    },
    options: {
      responsive: true,
      plugins: {
        legend: { display: false },
        tooltip: { callbacks: { label: (ctx) => ` ${ctx.label}: ${ctx.raw} đơn` } }
      },
      cutout: '65%'
    }
  });

  // ── 3. Bar Chart: Top thuốc bán chạy ─────────────────────────────
  new Chart(document.getElementById('topMedChart'), {
    type: 'bar',
    data: {
      labels: topMedData.map(d => d.name_medicine.length > 20 ? d.name_medicine.slice(0,20)+'...' : d.name_medicine),
      datasets: [{
        label: 'Số lượng bán',
        data: topMedData.map(d => d.total_qty),
        backgroundColor: ['#2563eb','#16a34a','#f59e0b','#dc2626','#7c3aed'],
        borderRadius: 6,
        borderSkipped: false
      }]
    },
    options: {
      responsive: true,
      indexAxis: 'y',
      plugins: {
        legend: { display: false },
        tooltip: {
          callbacks: {
            label: (ctx) => {
              const med = topMedData[ctx.dataIndex];
              return [` Số lượng: ${med.total_qty}`, ` Doanh thu: ${Number(med.total_revenue).toLocaleString('vi-VN')}đ`];
            }
          }
        }
      },
      scales: {
        x: { ticks: { stepSize: 1 } }
      }
    }
  });
</script>

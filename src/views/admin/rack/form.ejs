<div class="card"><div class="card-body"><form method="POST" action="/admin/rack/<%= item ? 'edit/'+item.id_rack : 'create' %>">
  <div class="row g-3">
    <div class="col-md-8"><label class="form-label">Tên kệ *</label><input type="text" name="name_rack" class="form-control" value="<%= item ? item.name_rack : '' %>" required></div>
    <div class="col-md-4"><label class="form-label">Trạng thái</label><select name="status" class="form-select"><option value="1" <%= item && item.status==1?'selected':'' %>>Sử dụng</option><option value="0" <%= item && item.status==0?'selected':'' %>>Đã ẩn</option></select></div>
    <div class="col-12"><label class="form-label">Mô tả</label><textarea name="descriptions" class="form-control" rows="3"><%= item ? item.descriptions || '' : '' %></textarea></div>
  </div>
  <div class="mt-3"><button class="btn btn-primary"><%= item ? 'Cập nhật' : 'Thêm mới' %></button> <a href="/admin/rack" class="btn btn-secondary">Hủy</a></div>
</form></div></div>

<div class="d-flex justify-content-between mb-3"><h5>Nhà cung cấp</h5><a href="/admin/supplier/create" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Thêm</a></div>
<div class="card"><div class="card-body p-0"><table class="table table-hover mb-0"><thead><tr><th>#</th><th>Tên NCC</th><th>SĐT</th><th>Email</th><th>Địa chỉ</th><th>Thao tác</th></tr></thead>
<tbody><% (items||[]).forEach((s,i) => { %><tr><td><%= i+1 %></td><td><%= s.name_supplier %></td><td><%= s.phone_supplier||'' %></td><td><%= s.gmail_supplier||'' %></td><td><%= s.address_supplier||'' %></td>
<td><a href="/admin/supplier/edit/<%= s.id_supplier %>" class="btn btn-warning btn-sm"><i class="bi bi-pencil"></i></a> <form method="POST" action="/admin/supplier/delete/<%= s.id_supplier %>" class="d-inline" onsubmit="return confirm('Xóa?')"><button class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button></form></td></tr><% }) %></tbody></table></div></div>

<div class='container'>
  <h1>Sửa Nhà sản xuất thuốc</h1>
  <form method='post' action='/admin/brands/edit/<%= item && item.id %>?_method=PUT'>
    <div>
      <label>Tên nhà sản xuất:</label>
      <input type='text' name='name' value='<%= item && item.name ? item.name : "" %>' placeholder='Tên nhà sản xuất'>
    </div>
    <div>
      <label>Mô tả:</label>
      <textarea name='description' placeholder='Mô tả nhà sản xuất'><%= item && item.description ? item.description : "" %></textarea>
    </div>
    <button type='submit'>Lưu</button>
  </form>
</div>

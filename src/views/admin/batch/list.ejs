<div class="d-flex justify-content-between mb-3"><h5>Lô hàng</h5><a href="/admin/batch/create" class="btn btn-primary btn-sm"><i class="bi bi-plus"></i> Nhập lô hàng</a></div>
<div class="card"><div class="card-body p-0"><table class="table table-hover mb-0"><thead><tr><th>#</th><th>Tên thuốc</th><th>Số lượng</th><th>Giá nhập</th><th>Ngày SX</th><th>Hạn sử dụng</th><th>Trạng thái</th><th>Thao tác</th></tr></thead>
<tbody><% (items||[]).forEach((b,i) => { %><tr><td><%= b.id_batch %></td><td><strong><%= b.name_medicine %></strong></td>
<td><%= b.quantity_in_batch %></td><td><%= Number(b.entry_price).toLocaleString('vi-VN') %>đ</td>
<td><%= b.manufacturing_date ? new Date(b.manufacturing_date).toLocaleDateString('vi-VN') : '' %></td>
<td class="<%= b.expiry_date && new Date(b.expiry_date) < new Date(Date.now() + 30*24*60*60*1000) ? 'text-danger fw-bold' : '' %>"><%= b.expiry_date ? new Date(b.expiry_date).toLocaleDateString('vi-VN') : '' %></td>
<td><span class="badge bg-<%= b.status=='con_hang'?'success':(b.status=='het_han'?'danger':'warning') %>"><%= b.status %></span></td>
<td><form method="POST" action="/admin/batch/delete/<%= b.id_batch %>" class="d-inline" onsubmit="return confirm('Cảnh báo: Xóa lô hàng không làm giảm tồn kho hiện tại. Tiếp tục?')"><button class="btn btn-danger btn-sm"><i class="bi bi-trash"></i></button></form></td></tr><% }) %></tbody></table></div></div>

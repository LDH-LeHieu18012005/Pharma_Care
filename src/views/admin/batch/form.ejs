<div class="card"><div class="card-body"><form method="POST" action="/admin/batch/create">
  <div class="row g-3">
    <div class="col-md-6"><label class="form-label">Chọn thuốc *</label>
      <select name="id_medicine" class="form-select" required><option value="">-- Chọn --</option><% (medicines||[]).forEach(m => { %><option value="<%= m.id_medicine %>"><%= m.name_medicine %> (Tồn: <%= m.quantity_total %>)</option><% }) %></select>
    </div>
    <div class="col-md-3"><label class="form-label">Số lượng nhập *</label><input type="number" name="quantity_in_batch" class="form-control" value="0" min="1" required></div>
    <div class="col-md-3"><label class="form-label">Giá nhập (VNĐ) *</label><input type="number" name="entry_price" class="form-control" value="0" min="0" required></div>
    <div class="col-md-4"><label class="form-label">Ngày sản xuất</label><input type="date" name="manufacturing_date" class="form-control"></div>
    <div class="col-md-4"><label class="form-label">Hạn sử dụng</label><input type="date" name="expiry_date" class="form-control"></div>
    <div class="col-md-4"><label class="form-label">Trạng thái</label><select name="status" class="form-select"><option value="con_hang">Còn hàng</option><option value="het_hang">Hết hàng</option><option value="het_han">Hết hạn</option></select></div>
    <div class="col-12"><label class="form-label">Ghi chú / Lý do hụt</label><textarea name="reason" class="form-control" rows="2"></textarea></div>
  </div>
  <div class="mt-3"><button class="btn btn-primary"><i class="bi bi-plus-circle"></i> Tạo lô & Cập nhật tồn kho</button> <a href="/admin/batch" class="btn btn-secondary">Hủy</a></div>
</form></div></div>

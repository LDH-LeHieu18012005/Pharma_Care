<div class='container'>
  <h1>Giỏ hàng</h1>
  <% const rows = Array.isArray(items) ? items : []; %>
  <% if (!rows.length) { %>
    <p>Giỏ hàng đang trống.</p>
  <% } else { %>
    <table border='1' cellpadding='8' cellspacing='0'>
      <thead><tr><th>ID</th><th>Tên</th><th>Số lượng</th><th>Đơn giá</th><th>Thao tác</th></tr></thead>
      <tbody>
        <% rows.forEach(function(row) { %>
          <tr>
            <td><%= row.id %></td>
            <td><%= row.name %></td>
            <td>
              <form method='post' action='/cart/update/<%= row.id %>'>
                <input type='number' name='quantity' value='<%= row.quantity %>' min='1'>
                <button type='submit'>Cập nhật</button>
              </form>
            </td>
            <td><%= row.unit_price || row.price || 0 %></td>
            <td>
              <form method='post' action='/cart/remove/<%= row.id %>'>
                <button type='submit'>Xóa</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
    <p>Tổng số lượng: <%= summary ? summary.totalQuantity : 0 %></p>
    <p>Tổng tiền: <%= summary ? summary.totalAmount : 0 %></p>
    <p><a href='/checkout'>Tiến hành thanh toán</a></p>
  <% } %>
</div>

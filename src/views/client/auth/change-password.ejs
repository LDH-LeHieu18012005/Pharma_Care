<div class='container'>
  <h1>Đổi mật khẩu</h1>
  <% if (typeof error !== 'undefined' && error) { %><p><%= error %></p><% } %>
  <form method='post' action='/change-password'>
    <div><input type='password' name='old_password' placeholder='Mật khẩu cũ'></div>
    <div><input type='password' name='new_password' placeholder='Mật khẩu mới'></div>
    <button type='submit'>Lưu</button>
  </form>
</div>

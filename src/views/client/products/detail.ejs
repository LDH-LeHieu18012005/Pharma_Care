<div class='container'>
  <h1>Chi tiết thuốc</h1>
  <% const data = item || product || null; %>
  <% if (!data) { %>
    <p>Không có dữ liệu.</p>
  <% } else { %>
    <table border='1' cellpadding='8' cellspacing='0'>
      <tbody>
        <% Object.keys(data).forEach(function(key) { %>
          <tr>
            <th><%= key === 'ingredients' ? 'Thành phần' : key === 'description' ? 'Công dụng' : key === 'price' ? 'Giá' : key === 'stock' ? 'Tồn kho' : key === 'name' ? 'Tên thuốc' : key %></th>
            <td><%= data[key] %></td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
  <p><a href='/products/'>Quay lại danh sách thuốc</a></p>
</div>

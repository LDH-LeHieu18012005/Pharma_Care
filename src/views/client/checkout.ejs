<div class="container mt-4 mb-5 min-vh-100">
  <h3 class="fw-bold mb-4" style="font-family: 'Be Vietnam Pro', sans-serif; color: var(--primary-dark);">Thanh toán đơn hàng</h3>

  <div class="row g-4">
    <!-- Checkout Form -->
    <div class="col-lg-7">
      <div class="card border-0 shadow-sm" style="border-radius: var(--radius-md);">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4">Thông tin giao hàng</h5>
          <form action="/checkout" method="POST" enctype="multipart/form-data">
            <div class="mb-3">
              <label class="form-label text-muted">Họ và tên người nhận</label>
              <input type="text" name="name" class="form-control" required placeholder="Nhập họ và tên">
            </div>
            
            <div class="mb-3">
              <label class="form-label text-muted">Số điện thoại</label>
              <input type="tel" name="phone" class="form-control" required placeholder="Nhập số điện thoại" pattern="[0-9]{10}">
            </div>
            
            <div class="mb-4">
              <label class="form-label text-muted">Địa chỉ nhận hàng</label>
              <textarea name="address" class="form-control" rows="3" required placeholder="Nhập số nhà, tên đường, phường/xã, quận/huyện, tỉnh/thành phố"></textarea>
            </div>

            <!-- Đơn thuốc bắt buộc -->
            <div class="mb-4">
              <label class="form-label fw-bold text-danger"><i class="bi bi-file-earmark-medical me-1"></i> Hình ảnh đơn thuốc <span class="badge bg-danger">Bắt buộc</span></label>
              <p class="text-muted small mb-2">Theo quy định, bạn cần cung cấp ảnh chụp đơn thuốc từ bác sĩ để mua thuốc kê đơn.</p>
              <input type="file" name="prescription_image" id="prescriptionInput" class="form-control" accept="image/*" required>
              <div id="prescriptionPreview" class="mt-3 d-none">
                <img id="previewImg" src="" alt="Xem trước đơn thuốc" class="img-fluid rounded border shadow-sm" style="max-height: 250px; object-fit: contain;">
              </div>
            </div>

            <h5 class="fw-bold mb-3 mt-4">Phương thức thanh toán</h5>
            <div class="form-check mb-2">
              <input class="form-check-input" type="radio" name="paymentMethod" id="cod" value="cod" checked>
              <label class="form-check-label fw-bold" for="cod">
                Thanh toán tiền mặt khi nhận hàng (COD)
              </label>
            </div>
            <div class="form-check mb-4">
              <input class="form-check-input" type="radio" name="paymentMethod" id="banking" value="banking" disabled>
              <label class="form-check-label text-muted" for="banking">
                Chuyển khoản qua ngân hàng (Đang bảo trì)
              </label>
            </div>

            <button type="submit" class="btn btn-primary w-100 py-3 fw-bold rounded-pill fs-5 shadow-sm mt-3">
              XÁC NHẬN ĐẶT HÀNG
            </button>
          </form>

          <script>
            document.getElementById('prescriptionInput').addEventListener('change', function(e) {
              const file = e.target.files[0];
              const preview = document.getElementById('prescriptionPreview');
              const previewImg = document.getElementById('previewImg');
              if (file) {
                const reader = new FileReader();
                reader.onload = function(ev) {
                  previewImg.src = ev.target.result;
                  preview.classList.remove('d-none');
                };
                reader.readAsDataURL(file);
              } else {
                preview.classList.add('d-none');
              }
            });
          </script>
        </div>
      </div>
    </div>

    <!-- Order Summary -->
    <div class="col-lg-5">
      <div class="card border-0 shadow-sm bg-light" style="border-radius: var(--radius-md);">
        <div class="card-body p-4">
          <h5 class="fw-bold mb-4">Đơn hàng của bạn (<%= cart.length %> sản phẩm)</h5>
          
          <div class="mb-4" style="max-height: 350px; overflow-y: auto;">
            <% cart.forEach(item => { %>
              <div class="d-flex align-items-center mb-3">
                <div class="position-relative me-3">
                  <% if (item.images) { %>
                    <img src="<%= item.images %>" alt="<%= item.name_medicine %>" class="rounded border bg-white" style="width: 60px; height: 60px; object-fit: cover;">
                  <% } else { %>
                    <div class="bg-white rounded border d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                      <i class="bi bi-image text-muted"></i>
                    </div>
                  <% } %>
                  <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-secondary border border-light">
                    <%= item.quantity %>
                  </span>
                </div>
                <div class="flex-grow-1">
                  <h6 class="mb-1 text-main fw-bold"><%= item.name_medicine %></h6>
                  <span class="text-primary fw-bold">
                    <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(item.price) %>
                  </span>
                </div>
              </div>
            <% }) %>
          </div>
          
          <hr>
          
          <div class="d-flex justify-content-between mb-3 text-muted">
            <span>Tạm tính:</span>
            <span><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(total) %></span>
          </div>
          <div class="d-flex justify-content-between mb-3 text-muted">
            <span>Phí vận chuyển:</span>
            <span class="text-success">Miễn phí</span>
          </div>
          
          <hr>
          
          <div class="d-flex justify-content-between align-items-end mt-3">
            <span class="fw-bold fs-5">Tổng tiền:</span>
            <span class="fw-bold fs-3 text-primary"><%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(total) %></span>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

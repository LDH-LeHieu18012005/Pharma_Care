<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Pharma Care</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <link href="/css/style.css" rel="stylesheet">
  <style>
    /* Specific client styles mirroring Long Chau */
    .client-header { background-color: var(--primary); color: white; padding: 15px 0; }
    .client-header a { color: white; text-decoration: none; }
    .client-header .brand-logo { font-size: 2rem; color: white !important; font-weight: 700; margin-bottom: 0; display: flex; align-items: center; gap: 10px; }
    .client-header .brand-logo i { color: white; font-size: 2rem; }
    .search-bar { background: white; border-radius: var(--radius-full); padding: 5px; display: flex; align-items: center; }
    .search-bar input { border: none; outline: none; background: transparent; padding: 8px 15px; width: 100%; }
    .search-bar .btn-search { background: var(--primary); color: white; border-radius: var(--radius-full); width: 40px; height: 40px; display: flex; align-items: center; justify-content: center; border: none; }
    .header-icon { font-size: 1.5rem; display: flex; align-items: center; justify-content: center; width: 40px; height: 40px; background: rgba(255,255,255,0.1); border-radius: 50%; transition: all 0.2s; }
    .header-icon:hover { background: rgba(255,255,255,0.2); }
    .header-action { display: flex; align-items: center; gap: 10px; cursor: pointer; }
    
    .client-nav { background-color: white; border-bottom: 1px solid var(--border); box-shadow: var(--shadow-sm); }
    .client-nav .nav-link { color: var(--text-main); font-weight: 600; padding: 15px 20px; transition: color 0.2s; }
    .client-nav .nav-link:hover { color: var(--primary); }
    
    .footer { background-color: white; padding: 40px 0; margin-top: 40px; border-top: 1px solid var(--border); }
    .footer-title { font-family: 'Be Vietnam Pro', sans-serif; font-weight: 700; color: var(--primary-dark); margin-bottom: 20px; font-size: 1.2rem; }
    .footer-link { color: var(--text-muted); text-decoration: none; display: block; margin-bottom: 10px; transition: color 0.2s; }
    .footer-link:hover { color: var(--primary); }
  </style>
</head>
<body style="background-color: #F8F9FA;">

  <!-- Top Header -->
  <header class="client-header">
    <div class="container">
      <div class="row align-items-center">
        <!-- Logo -->
        <div class="col-lg-3 col-md-4 mb-3 mb-md-0">
          <a href="/" class="brand-logo">
            <i class="bi bi-capsule-pill"></i> Pharma Care
          </a>
        </div>
        
        <!-- Search Bar -->
        <div class="col-lg-5 col-md-8 mb-3 mb-lg-0">
          <form action="/search" method="GET" class="search-bar shadow-sm">
            <input type="text" name="q" placeholder="Tìm kiếm tên thuốc, triệu chứng..." value="<%= typeof q !== 'undefined' ? q : '' %>" required>
            <button type="submit" class="btn-search"><i class="bi bi-search"></i></button>
          </form>
        </div>
        
        <!-- Actions -->
        <div class="col-lg-4 d-flex justify-content-lg-end gap-4 align-items-center">
          <a href="/cart" class="header-action text-decoration-none">
            <div class="header-icon position-relative text-white">
              <i class="bi bi-cart3"></i>
              <% if (typeof cart !== 'undefined' && cart.length > 0) { %>
                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger" style="font-size: 0.65rem;">
                  <%= cart.length %>
                </span>
              <% } %>
            </div>
            <div class="d-none d-sm-block text-white">
              <span class="d-block small opacity-75">Giỏ hàng</span>
              <span class="fw-bold">
                <% 
                  let cartTotal = 0;
                  if (typeof cart !== 'undefined') {
                    cart.forEach(item => cartTotal += item.price * item.quantity);
                  }
                %>
                <%= new Intl.NumberFormat('vi-VN', { style: 'currency', currency: 'VND' }).format(cartTotal) %>
              </span>
            </div>
          </a>
          
          <% if (currentUser) { %>
            <div class="header-action dropdown">
              <div class="header-icon" data-bs-toggle="dropdown" style="cursor: pointer;">
                <i class="bi bi-person"></i>
              </div>
              <ul class="dropdown-menu dropdown-menu-end shadow border-0 mt-2">
                <li><a class="dropdown-item py-2" href="/admin">Quản trị Hệ thống</a></li>
                <li><hr class="dropdown-divider"></li>
                <li><a class="dropdown-item py-2 text-danger" href="/logout"><i class="bi bi-box-arrow-right me-2"></i> Đăng xuất</a></li>
              </ul>
            </div>
          <% } else { %>
            <div class="header-action">
              <div class="header-icon"><i class="bi bi-person"></i></div>
              <div class="d-none d-sm-block">
                <a href="/login" class="d-block fw-bold text-white text-decoration-none">Đăng nhập</a>
              </div>
            </div>
          <% } %>
        </div>
      </div>
    </div>
  </header>

  <!-- Navigation -->
  <nav class="client-nav sticky-top">
    <div class="container">
      <div class="d-flex overflow-auto">
        <a href="#" class="nav-link text-nowrap"><i class="bi bi-grid-fill me-2 text-primary"></i>Danh mục</a>
        <a href="#" class="nav-link text-nowrap">Thực phẩm chức năng</a>
        <a href="#" class="nav-link text-nowrap">Dược mỹ phẩm</a>
        <a href="#" class="nav-link text-nowrap">Chăm sóc cá nhân</a>
        <a href="#" class="nav-link text-nowrap">Thiết bị y tế</a>
        <a href="#" class="nav-link text-nowrap">Góc sức khỏe</a>
      </div>
    </div>
  </nav>

  <!-- Main Content -->
  <main class="min-vh-100">
    <%- body %>
  </main>

  <!-- Footer -->
  <footer class="footer">
    <div class="container">
      <div class="row">
        <div class="col-lg-4 mb-4">
          <a href="/" class="brand-logo text-decoration-none text-primary d-flex align-items-center gap-2 fs-3 fw-bold mb-3" style="font-family: 'Be Vietnam Pro', sans-serif;">
            <i class="bi bi-capsule-pill"></i> Pharma Care
          </a>
          <p class="text-muted">Hệ thống nhà thuốc uy tín, chuyên cung cấp các loại thuốc, thực phẩm chức năng và thiết bị y tế chính hãng.</p>
          <div class="d-flex gap-3 mt-3">
            <a href="#" class="header-icon bg-light text-primary"><i class="bi bi-facebook"></i></a>
            <a href="#" class="header-icon bg-light text-primary"><i class="bi bi-youtube"></i></a>
            <a href="#" class="header-icon bg-light text-primary"><i class="bi bi-tiktok"></i></a>
          </div>
        </div>
        <div class="col-lg-2 col-md-6 mb-4">
          <h5 class="footer-title">Về chúng tôi</h5>
          <a href="#" class="footer-link">Giới thiệu</a>
          <a href="#" class="footer-link">Hệ thống cửa hàng</a>
          <a href="#" class="footer-link">Quy chế hoạt động</a>
          <a href="#" class="footer-link">Chính sách bảo mật</a>
        </div>
        <div class="col-lg-3 col-md-6 mb-4">
          <h5 class="footer-title">Hỗ trợ khách hàng</h5>
          <a href="#" class="footer-link">Điều kiện giao dịch</a>
          <a href="#" class="footer-link">Chính sách đổi trả</a>
          <a href="#" class="footer-link">Chính sách giao hàng</a>
          <a href="#" class="footer-link">Thanh toán & Hóa đơn</a>
        </div>
        <div class="col-lg-3 col-md-6 mb-4">
          <h5 class="footer-title">Tổng đài CSKH</h5>
          <div class="bg-primary text-white p-3 rounded-3 mb-2">
            <small class="d-block opacity-75">Tư vấn mua hàng</small>
            <strong class="fs-4">1800 6928</strong>
          </div>
          <div class="bg-light p-3 rounded-3">
            <small class="d-block text-muted">Góp ý, khiếu nại</small>
            <strong class="fs-5 text-primary">1800 6929</strong>
          </div>
        </div>
      </div>
    </div>
  </footer>

  <!-- Chatbot Widget -->
  <div id="chat-widget" class="position-fixed" style="bottom: 20px; right: 20px; z-index: 1050;">
    <!-- Chat Button -->
    <button id="chat-toggle-btn" class="btn btn-primary rounded-circle shadow-lg d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
      <i class="bi bi-chat-dots-fill fs-3 text-white"></i>
    </button>
    
    <!-- Chat Box -->
    <div id="chat-box" class="card shadow-lg d-none" style="width: 350px; height: 450px; position: absolute; bottom: 80px; right: 0; border-radius: var(--radius-md); overflow: hidden;">
      <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
        <div class="fw-bold"><i class="bi bi-robot me-2"></i>Dược sĩ Pharma Care</div>
        <button type="button" class="btn-close btn-close-white" id="chat-close-btn" aria-label="Close"></button>
      </div>
      <div class="card-body bg-light" id="chat-messages" style="overflow-y: auto; height: 320px;">
        <div class="d-flex mb-3">
          <div class="bg-white p-2 rounded shadow-sm" style="max-width: 85%; font-size: 0.9rem;">
            Xin chào! Tôi là dược sĩ ảo của Pharma Care. Tôi có thể giúp gì cho bạn?
          </div>
        </div>
      </div>
      <div class="card-footer bg-white border-top-0 p-2">
        <form id="chat-form" class="d-flex gap-2">
          <input type="text" id="chat-input" class="form-control rounded-pill" placeholder="Nhập tin nhắn..." autocomplete="off">
          <button type="submit" class="btn btn-primary rounded-circle" style="width: 40px; height: 40px; padding: 0;">
            <i class="bi bi-send-fill"></i>
          </button>
        </form>
      </div>
    </div>
  </div>
  
  <script>
    document.addEventListener('DOMContentLoaded', () => {
      const chatToggleBtn = document.getElementById('chat-toggle-btn');
      const chatCloseBtn = document.getElementById('chat-close-btn');
      const chatBox = document.getElementById('chat-box');
      const chatForm = document.getElementById('chat-form');
      const chatInput = document.getElementById('chat-input');
      const chatMessages = document.getElementById('chat-messages');

      const toggleChat = () => chatBox.classList.toggle('d-none');
      
      chatToggleBtn.addEventListener('click', toggleChat);
      chatCloseBtn.addEventListener('click', () => chatBox.classList.add('d-none'));

      const appendMessage = (msg, isUser) => {
        const msgDiv = document.createElement('div');
        msgDiv.className = `d-flex mb-3 ${isUser ? 'justify-content-end' : ''}`;
        
        const innerDiv = document.createElement('div');
        innerDiv.className = `p-2 rounded shadow-sm ${isUser ? 'bg-primary text-white' : 'bg-white'}`;
        innerDiv.style.maxWidth = '85%';
        innerDiv.style.fontSize = '0.9rem';
        innerDiv.textContent = msg;
        
        msgDiv.appendChild(innerDiv);
        chatMessages.appendChild(msgDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
      };

      chatForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const message = chatInput.value.trim();
        if (!message) return;
        
        appendMessage(message, true);
        chatInput.value = '';
        
        const loadingId = 'loading-' + Date.now();
        const loadingDiv = document.createElement('div');
        loadingDiv.id = loadingId;
        loadingDiv.className = 'd-flex mb-3 text-muted small';
        loadingDiv.innerHTML = '<i>Đang trả lời...</i>';
        chatMessages.appendChild(loadingDiv);
        chatMessages.scrollTop = chatMessages.scrollHeight;
        
        try {
          const res = await fetch('/chat', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ message })
          });
          const data = await res.json();
          document.getElementById(loadingId).remove();
          appendMessage(data.reply || 'Xin lỗi, tôi không thể trả lời lúc này.', false);
        } catch (error) {
          if (document.getElementById(loadingId)) document.getElementById(loadingId).remove();
          appendMessage('Lỗi kết nối. Vui lòng thử lại sau.', false);
        }
      });
    });
  </script>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

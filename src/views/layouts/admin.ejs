<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Pharma Care</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
  <style>
    body { font-family: 'Segoe UI', sans-serif; background: #f0f2f5; }
    .sidebar { width: 250px; min-height: 100vh; background: #1a237e; position: fixed; top: 0; left: 0; color: #fff; }
    .sidebar .brand { padding: 20px; font-size: 1.3rem; font-weight: 700; border-bottom: 1px solid rgba(255,255,255,.1); }
    .sidebar .nav-link { color: rgba(255,255,255,.7); padding: 10px 20px; display: flex; align-items: center; gap: 10px; text-decoration: none; font-size: .9rem; }
    .sidebar .nav-link:hover, .sidebar .nav-link.active { color: #fff; background: rgba(255,255,255,.1); }
    .sidebar .nav-link i { font-size: 1.1rem; width: 20px; text-align: center; }
    .main-content { margin-left: 250px; padding: 20px; }
    .topbar { background: #fff; padding: 12px 20px; margin: -20px -20px 20px; box-shadow: 0 1px 3px rgba(0,0,0,.1); display: flex; justify-content: space-between; align-items: center; }
    .card-stat { border: none; border-radius: 12px; box-shadow: 0 2px 8px rgba(0,0,0,.08); }
    .card-stat .card-body { padding: 20px; }
    .card-stat .stat-icon { width: 50px; height: 50px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 1.5rem; }
    .table th { background: #f8f9fa; font-weight: 600; font-size: .85rem; text-transform: uppercase; }
    .btn-sm { font-size: .8rem; }
  </style>
</head>
<body>
  <div class="sidebar">
    <div class="brand"><i class="bi bi-capsule"></i> Pharma Care</div>
    <nav class="mt-2">
      <a class="nav-link" href="/admin"><i class="bi bi-speedometer2"></i> Dashboard</a>
      <a class="nav-link" href="/admin/medicine"><i class="bi bi-capsule"></i> Thuốc</a>
      <a class="nav-link" href="/admin/medicine-type"><i class="bi bi-tags"></i> Loại thuốc</a>
      <a class="nav-link" href="/admin/rack"><i class="bi bi-grid-3x3-gap"></i> Kệ thuốc</a>
      <a class="nav-link" href="/admin/batch"><i class="bi bi-box-seam"></i> Lô hàng</a>
      <a class="nav-link" href="/admin/supplier"><i class="bi bi-truck"></i> Nhà cung cấp</a>
      <a class="nav-link" href="/admin/customer"><i class="bi bi-people"></i> Khách hàng</a>
      <a class="nav-link" href="/admin/sales"><i class="bi bi-receipt"></i> Hóa đơn bán</a>
      <% if (currentUser && currentUser.permission === 'admin') { %>
      <a class="nav-link" href="/admin/staff"><i class="bi bi-person-badge"></i> Nhân viên</a>
      <% } %>
      <hr style="border-color: rgba(255,255,255,.15); margin: 8px 20px;">
      <a class="nav-link" href="/logout"><i class="bi bi-box-arrow-left"></i> Đăng xuất</a>
    </nav>
  </div>
  <div class="main-content">
    <div class="topbar">
      <h5 class="mb-0"><%= title %></h5>
      <span class="text-muted"><i class="bi bi-person-circle"></i> <%= currentUser ? currentUser.name : '' %> (<%= currentUser ? currentUser.permission : '' %>)</span>
    </div>
    <%- body %>
  </div>
  <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>

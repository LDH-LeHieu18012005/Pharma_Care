<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %> | Pharma Care</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <style>
    body { background: linear-gradient(135deg, #1a237e 0%, #0d47a1 100%); min-height: 100vh; display: flex; align-items: center; justify-content: center; font-family: 'Segoe UI', sans-serif; }
    .login-card { background: #fff; border-radius: 16px; box-shadow: 0 20px 60px rgba(0,0,0,.3); padding: 40px; width: 100%; max-width: 420px; }
    .login-card h2 { color: #1a237e; font-weight: 700; }
    .login-card .form-control { border-radius: 8px; padding: 12px; }
    .login-card .btn-primary { background: #1a237e; border: none; border-radius: 8px; padding: 12px; font-weight: 600; }
    .login-card .btn-primary:hover { background: #283593; }
  </style>
</head>
<body>
  <%- body %>
</body>
</html>
